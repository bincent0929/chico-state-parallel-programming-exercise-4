        "sixteen_proc_completion_time = 0.362"
      ],
      "id": "5d97d9cf",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "In this instance, `--use-hwthread-cpus` allows me to segment the CPU as hardware threads instead of cores. Which enables me to utilize each thread as if it where its own core.\n",
        "\n",
        "#### Completion Time vs Number of Processes (dt=0.0001)"
      ],
      "id": "25e612d7"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import plotly.graph_objects as go\n",
        "\n",
        "num_procs = [1, 2, 4, 8, 16]\n",
        "completion_times = [\n",
        "    smaller_step_runtime,       # 1 process (sequential dt=0.0001)\n",
        "    two_proc_completion_time,   # 2 processes\n",
        "    four_proc_completion_time,  # 4 processes\n",
        "    eight_proc_completion_time, # 8 processes\n",
        "    sixteen_proc_completion_time # 16 processes\n",
        "]\n",
        "\n",
        "fig = go.Figure()\n",
        "\n",
        "fig.add_trace(go.Scatter(\n",
        "    x=num_procs,\n",
        "    y=completion_times,\n",
        "    mode='lines+markers',\n",
        "    name='Wall-clock time',\n",
        "    line=dict(color='royalblue', width=2),\n",
        "    marker=dict(size=10, symbol='circle'),\n",
        "))\n",
        "\n",
        "fig.update_layout(\n",
        "    title='MPI Scaling: Completion Time vs Number of Processes (dt=0.0001)',\n",
        "    xaxis=dict(\n",
        "        title='Number of MPI Processes',\n",
        "        tickmode='array',\n",
        "        tickvals=num_procs,\n",
        "    ),\n",
        "    yaxis_title='Completion Time (seconds)',\n",
        "    hovermode='x unified',\n",
        ")\n",
        "\n",
        "fig.show()"
      ],
      "id": "fbb3bf3b",
      "execution_count": null,
      "outputs": []
    }
  ],
